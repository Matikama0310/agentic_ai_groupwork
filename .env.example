# Anthropic API Key
ANTHROPIC_API_KEY=sk-your-key-here

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# MVP Settings
MOCK_EXTERNAL_APIS=true
STATE_BACKEND=memory

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Service Configuration
SUBMISSION_TIMEOUT_SECONDS=30
EXTRACTION_CONFIDENCE_THRESHOLD=0.50
