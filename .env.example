# =============================================================================
# NorthStar Insurance - Agentic Underwriting System
# Environment Configuration
# =============================================================================
# Copy this to .env and fill in your actual credentials before running.

# -----------------------------------------------------------------------------
# LLM / AI Provider (Required for production; MVP uses mock tools)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# -----------------------------------------------------------------------------
# AWS Configuration (Required for Lambda deployment & S3 PDF storage)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_PROFILE=default
S3_QUOTES_BUCKET=northstar-quotes

# -----------------------------------------------------------------------------
# Third-Party Data APIs (Data Retriever Agents)
# -----------------------------------------------------------------------------
DNB_API_KEY=your-dnb-api-key
DNB_API_SECRET=your-dnb-api-secret
HAZARDHUB_API_KEY=your-hazardhub-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# Document Understanding (OCR / Document AI)
# -----------------------------------------------------------------------------
AZURE_DOCUMENT_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_KEY=your-azure-document-key

# -----------------------------------------------------------------------------
# Communication (Broker Liaison Agent)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@company.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=underwriting@northstar-insurance.com
MS_GRAPH_CLIENT_ID=your-client-id
MS_GRAPH_CLIENT_SECRET=your-client-secret
MS_GRAPH_TENANT_ID=your-tenant-id
CALENDAR_API_KEY=your-calendar-api-key

# -----------------------------------------------------------------------------
# RAG Knowledge Base (Decision Logic / Guidelines)
# -----------------------------------------------------------------------------
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=underwriting-guidelines
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
MOCK_EXTERNAL_APIS=true
STATE_BACKEND=memory
DYNAMODB_TABLE_NAME=northstar-underwriting-submissions
LOG_LEVEL=INFO
LOG_FORMAT=json
SUBMISSION_TIMEOUT_SECONDS=30
EXTRACTION_CONFIDENCE_THRESHOLD=0.50
MAX_WORKFLOW_RETRIES=3
API_HOST=0.0.0.0
API_PORT=8000
